#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <Keypad.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {2,3,4,5};
byte colPins[COLS] = {6,7,8,9};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

int greenLED = 10;
int redLED = 11;
int buzzer = 12;

String secretCode = "";
String userInput = "";

void setup() {

  pinMode(greenLED, OUTPUT);
  pinMode(redLED, OUTPUT);
  pinMode(buzzer, OUTPUT);

  lcd.init();
  lcd.backlight();

  randomSeed(analogRead(A0));

  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("MEMORY GAME");
  delay(2000);
}

void loop() {

  for(int roundNum = 1; roundNum <= 5; roundNum++) {

    int digits = roundNum + 3;

    secretCode = "";

    for(int i = 0; i < digits; i++) {
      secretCode += String(random(0,10));
    }

    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print("ROUND ");
    lcd.print(roundNum);

    lcd.setCursor(0,1);
    lcd.print("MEMORIZE");

    delay(2000);

    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print(secretCode);

    delay(3000);

    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print("ENTER CODE");

    userInput = "";

    while(true) {

      char key = keypad.getKey();

      if(key) {

        if(key >= '0' && key <= '9') {

          userInput += key;

          lcd.setCursor(0,1);
          lcd.print("                ");

          lcd.setCursor(0,1);
          lcd.print(userInput);
        }

        else if(key == 'C') {

          userInput = "";

          lcd.setCursor(0,1);
          lcd.print("                ");
        }

        else if(key == '#') {

          break;
        }
      }
    }

    if(userInput == secretCode) {

      lcd.clear();
      lcd.setCursor(0,0);
      lcd.print("CORRECT!");

      digitalWrite(greenLED, HIGH);

      tone(buzzer, 2000, 200);

      delay(1500);

      digitalWrite(greenLED, LOW);
    }

    else {

      lcd.clear();
      lcd.setCursor(0,0);
      lcd.print("INCORRECT!");

      digitalWrite(redLED, HIGH);

      tone(buzzer, 500, 1000);

      delay(2000);

      lcd.clear();
      lcd.setCursor(0,0);
      lcd.print("YOUR ANSWER");

      lcd.setCursor(0,1);
      lcd.print(userInput);

      delay(3000);

      lcd.clear();
      lcd.setCursor(0,0);
      lcd.print("CORRECT ANS");

      lcd.setCursor(0,1);
      lcd.print(secretCode);

      delay(3000);

      digitalWrite(redLED, LOW);

      lcd.clear();
      lcd.setCursor(0,0);
      lcd.print("GAME OVER");

      lcd.setCursor(0,1);
      lcd.print("RESTARTING");

      delay(2000);

      return;
    }
  }

  lcd.clear();
  lcd.setCursor(0,0);
  lcd.print("YOU WIN!");

  lcd.setCursor(0,1);
  lcd.print("MEMORY MASTER");

  digitalWrite(greenLED, HIGH);

  tone(buzzer, 2500, 500);

  delay(5000);

  digitalWrite(greenLED, LOW);
}
