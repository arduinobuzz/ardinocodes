#include <SPI.h>
#include <MFRC522.h>
#include <Keypad.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

#define SS_PIN 10
#define RST_PIN 9
#define BUZZER 2

MFRC522 rfid(SS_PIN, RST_PIN);
LiquidCrystal_I2C lcd(0x27, 16, 2);

byte allowedUID[4] = { 0xE9, 0xA6, 0x9F, 0x11 };

const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  { '1', '2', '3', 'A' },
  { '4', '5', '6', 'B' },
  { '7', '8', '9', 'C' },
  { '*', '0', '#', 'D' }
};

byte rowPins[ROWS] = { 3, 4, 5, 6 };
byte colPins[COLS] = { 7, 8, A0, A1 };

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

String amount = "";

void beep() {
  digitalWrite(BUZZER, HIGH);
  delay(150);
  digitalWrite(BUZZER, LOW);
}

bool cardAccepted() {
  for (byte i = 0; i < 4; i++) {
    if (rfid.uid.uidByte[i] != allowedUID[i])
      return false;
  }
  return true;
}

void setup() {
  pinMode(BUZZER, OUTPUT);

  SPI.begin();
  rfid.PCD_Init();

  lcd.init();
  lcd.backlight();

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Tap Credit Card");
}

void loop() {
  if (!rfid.PICC_IsNewCardPresent())
    return;

  if (!rfid.PICC_ReadCardSerial())
    return;

  beep();

  if (!cardAccepted()) {
    beep();
    delay(100);
    beep();

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Wrong Credit");

    lcd.setCursor(0, 1);
    lcd.print("Card!");

    delay(3000);

    lcd.clear();
    lcd.print("Tap Credit Card");

    rfid.PICC_HaltA();
    return;
  }

  lcd.clear();
  lcd.print("Enter Amount:");

  amount = "";

  while (true) {
    char key = keypad.getKey();

    if (key) {
      if (key >= '0' && key <= '9') {
        if (amount.length() < 5) {
          amount += key;

          lcd.setCursor(0, 1);
          lcd.print("                ");
          lcd.setCursor(0, 1);
          lcd.print(amount);
        }
      }

      if (key == '*') {
        amount = "";

        lcd.setCursor(0, 1);
        lcd.print("                ");
      }

      if (key == '#') {
        int value = amount.toInt();

        if (value <= 0) {
          lcd.clear();
          lcd.print("Invalid Amount");
          delay(2000);
          break;
        }

        if (value > 10000) {
          lcd.clear();
          lcd.print("Limit Exceeded");
          lcd.setCursor(0, 1);
          lcd.print("Max $10000");
          delay(2500);
          break;
        }

        lcd.clear();
        lcd.print("Processing...");
        delay(2000);

        beep();
        delay(100);
        beep();

        lcd.clear();
        lcd.print("Removed $");
        lcd.print(value);

        lcd.setCursor(0, 1);
        lcd.print("From Bank");

        delay(4000);
        break;
      }
    }
  }

  lcd.clear();
  lcd.print("Tap Credit Card");

  rfid.PICC_HaltA();
}
