#include <Arduino.h>
#include <U8g2lib.h>
#include <Wire.h>

U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0);

#define JOY_X A1
#define JOY_SW 2
#define BUZZER 8

int lanes[3] = { 24, 64, 104 };
int carLane = 1;
int obstacleLane;
int obstacleY = -10;
int obstacle2Lane;
int obstacle2Y = -40;
int coinLane;
int coinY = -20;
int lives = 3;

long score = 0;
long highScore = 0;

bool gameOver = false;

unsigned long lastMove = 0;
int speedDelay = 70;

void restartGame() {
  coinLane = random(0, 3);
  coinY = -20;
  if (score > highScore) {
    highScore = score;
  }

  score = 0;
  lives = 3;

  carLane = 1;

  obstacleLane = random(0, 3);
  obstacleY = -10;

  gameOver = false;
  speedDelay = 70;
}

void setup() {
  pinMode(JOY_SW, INPUT_PULLUP);

  pinMode(BUZZER, OUTPUT);
  digitalWrite(BUZZER, LOW);

  randomSeed(millis());

  u8g2.begin();

  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_6x12_tf);
  u8g2.drawStr(18, 20, "ARDUINO RACING");
  u8g2.drawStr(12, 40, "Press Joystick");
  u8g2.drawStr(20, 55, "To Start");
  u8g2.sendBuffer();

  while (digitalRead(JOY_SW) == HIGH)
    ;
  delay(300);

  restartGame();
}

void loop() {

  if (gameOver) {
    if (digitalRead(JOY_SW) == LOW) {
      restartGame();
      delay(300);
    }
  }

  if (!gameOver) {

    int xVal = analogRead(JOY_X);

    if (xVal < 300 && carLane < 2) {
      carLane++;
      delay(80);
    }

    if (xVal > 700 && carLane > 0) {
      carLane--;
      delay(80);
    }


    if (millis() - lastMove > speedDelay) {

      coinY += 3;

      if (coinY > 64) {
        coinY = -20;
        coinLane = random(0, 3);
      }


      obstacle2Y += 4;

      if (obstacle2Y > 64) {
        obstacle2Y = -40;
        obstacle2Lane = random(0, 3);
      }
      obstacleY += 4;

      if (obstacleY > 64) {
        obstacleY = -10;
        obstacleLane = random(0, 3);

        score++;

        if (score % 5 == 0 && speedDelay > 25) {
          speedDelay -= 3;
        }
      }

      lastMove = millis();
    }

    int carX = lanes[carLane];
    int obsX = lanes[obstacleLane];

    if (coinLane == carLane && coinY > 46 && coinY < 60) {

      score += 1;

      digitalWrite(BUZZER, HIGH);
      delay(30);
      digitalWrite(BUZZER, LOW);

      coinY = -20;
      coinLane = random(0, 3);
    }

    if (obstacleY > 46 && obstacleY < 60 && abs(carX - obsX) < 10) {

      lives--;

      digitalWrite(BUZZER, HIGH);
      delay(100);
      digitalWrite(BUZZER, LOW);

      obstacleY = -10;
      obstacleLane = random(0, 3);
      obstacle2Lane = random(0, 3);
      obstacle2Y = -40;

      if (lives <= 0) {
        gameOver = true;

        if (score > highScore) {
          highScore = score;
        }
      }
    }
  }

  int carX = lanes[carLane];
  int obsX = lanes[obstacleLane];

  u8g2.clearBuffer();

  u8g2.drawLine(44, 0, 44, 64);
  u8g2.drawLine(84, 0, 84, 64);

  // Car
  u8g2.drawBox(carX - 6, 52, 12, 8);
  u8g2.drawBox(carX - 4, 48, 8, 4);

  // Obstacle
  u8g2.drawBox(obsX - 5, obstacleY, 10, 10);

  u8g2.drawBox(lanes[obstacle2Lane] - 5, obstacle2Y, 10, 10);

  u8g2.drawDisc(lanes[coinLane], coinY, 3);

  // HUD
  char buf[20];

  u8g2.setFont(u8g2_font_5x8_tf);

  sprintf(buf, "Lv:%d", lives);
  u8g2.drawStr(0, 10, buf);

  sprintf(buf, "S:%ld", score);
  u8g2.drawStr(40, 10, buf);

  sprintf(buf, "H:%ld", highScore);
  u8g2.drawStr(72, 10, buf);

  if (gameOver) {
    u8g2.drawBox(12, 18, 104, 30);

    u8g2.setDrawColor(0);
    u8g2.drawStr(28, 32, "GAME OVER");
    u8g2.drawStr(14, 44, "Press Joystick");
    u8g2.setDrawColor(1);
  }

  u8g2.sendBuffer();
}
