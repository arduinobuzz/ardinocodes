#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27,16,2);

#define TOUCH 2
#define START 3
#define BUZZER 5

float target;
float player;
float difference;

float totalDifference;

void waitFingerRelease(){

bool shown=false;

while(
digitalRead(TOUCH)
){

if(!shown){

lcd.clear();

lcd.setCursor(0,0);
lcd.print("REMOVE");

lcd.setCursor(3,1);
lcd.print("FINGER");

shown=true;

}

delay(20);

}

}



void waitButton(
const char* msg
){

lcd.clear();

lcd.setCursor(0,0);
lcd.print("PRESS BUTTON");

lcd.setCursor(1,1);
lcd.print(msg);

while(
digitalRead(START)==HIGH
){

delay(20);

}

delay(300);

lcd.clear();

}



void setup(){

pinMode(
TOUCH,
INPUT
);

pinMode(
START,
INPUT_PULLUP
);

pinMode(
BUZZER,
OUTPUT
);

lcd.init();

lcd.backlight();

randomSeed(
analogRead(A0)
);

}



void loop(){

totalDifference=0;


// START

waitButton(
"TO START"
);




// 3 ROUNDS

for(
int round=1;
round<=3;
round++
){


// ROUND

lcd.clear();

if(round<3){

lcd.setCursor(
3,
0
);

lcd.print(
"ROUND "
);

lcd.print(
round
);

}

else{

lcd.setCursor(
2,
0
);

lcd.print(
"FINAL ROUND"
);

}

delay(
1500
);




// TARGET

target=
random(
300,
1001
)
/100.0;


lcd.clear();

lcd.print(
"STOP AT"
);

lcd.setCursor(
4,
1
);

lcd.print(
target
);

lcd.print(
" sec"
);

delay(
2500
);



waitFingerRelease();




// WAIT

lcd.clear();

lcd.setCursor(
5,
0
);

lcd.print(
"WAIT"
);

unsigned long wait=
random(
2000,
5001
);

unsigned long ws=
millis();

while(
millis()-ws<wait
){

if(
digitalRead(
TOUCH
)
){

waitFingerRelease();

lcd.clear();

lcd.setCursor(
5,
0
);

lcd.print(
"WAIT"
);

ws=
millis();

}

delay(10);

}




// COUNTDOWN

for(
int i=3;
i>=1;
i--
){

lcd.clear();

lcd.setCursor(
7,
0
);

lcd.print(
i
);

unsigned long t=
millis();

while(
millis()-t<1000
){

if(
digitalRead(
TOUCH
)
){

waitFingerRelease();

lcd.clear();

lcd.setCursor(
7,
0
);

lcd.print(
i
);

t=
millis();

}

delay(20);

}

}




// GO

lcd.clear();

lcd.setCursor(
6,
0
);

lcd.print(
"GO"
);

tone(
BUZZER,
1000,
100
);

unsigned long start=
millis();




// TIMER

while(
!digitalRead(
TOUCH
)
){

player=
(
millis()-start
)
/1000.0;


lcd.setCursor(
0,
0
);

lcd.print(
"STOP:");

lcd.print(
target
);

lcd.print(
"s ");


lcd.setCursor(
0,
1
);

lcd.print(
player
);

lcd.print(
" sec ");


delay(20);

}




// STOP

player=
(
millis()-start
)
/1000.0;

difference=
abs(
target-player
);

totalDifference+=difference;




// YOUR TIME

lcd.clear();

lcd.print(
"YOUR TIME"
);

lcd.setCursor(
0,
1
);

lcd.print(
player
);

lcd.print(
" sec"
);

delay(
2500
);




// DIFFERENCE

lcd.clear();

lcd.print(
"DIFFERENCE"
);

lcd.setCursor(
0,
1
);

lcd.print(
difference
);

lcd.print(
" sec"
);

delay(
2500
);

}


// FINAL RESULT

float total=
totalDifference;

lcd.clear();

lcd.print(
"FINAL RESULT"
);

delay(
2000
);

lcd.clear();


if(
total<=0.10
){

lcd.print(
"INSANE"
);

tone(
BUZZER,
1800,
400
);

}

else if(
total<=0.50
){

lcd.print(
"BETTER THAN"
);

lcd.setCursor(
0,
1
);

lcd.print(
"AVERAGE"
);

}

else if(
total<=0.80
){

lcd.print(
"AVERAGE"
);

}

else{

lcd.print(
"BAD"
);

}

delay(
5000
);
// RESTART

waitButton(
"TO RESTART"
);

}
