#include <Wire.h>
#include <U8g2lib.h>

U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(
U8G2_R0,
U8X8_PIN_NONE
);

#define BUTTON 2
#define BUZZER 5

float y=40;
float v=0;

int cactus=128;

int score=0;

bool dead=false;

bool lock=false;

void setup(){

pinMode(BUTTON,INPUT_PULLUP);

pinMode(BUZZER,OUTPUT);

u8g2.begin();

randomSeed(analogRead(A0));

}



void loop(){


// GAME OVER

if(dead){

u8g2.clearBuffer();

u8g2.setFont(
u8g2_font_6x12_tr
);

u8g2.drawStr(
20,
20,
"GAME OVER"
);

u8g2.setCursor(
20,
40
);

u8g2.print(
"Score:"
);

u8g2.print(
score
);

u8g2.drawStr(
10,
58,
"Press button to play"
);

u8g2.sendBuffer();


if(
!digitalRead(BUTTON)
){

score=0;

cactus=128;

y=40;

v=0;

dead=false;

delay(300);

}

return;

}



// JUMP

if(
!digitalRead(BUTTON)
&&
!lock
&&
y>=40
){

v=-14;

lock=true;

}

if(
digitalRead(BUTTON)
){

lock=false;

}



// PHYSICS

v+=2.5;

y+=v;

if(
y>40
){

y=40;

v=0;

}



// SPEED

int speed;

if(score<20)
speed=4;

else if(score<40)
speed=6;

else
speed=8;



// MOVE

cactus-=speed;

if(
cactus<-60
){

cactus=128;

score++;

}



// COLLISION

bool hit=false;


if(
cactus<28
&&
cactus>10
&&
y>32
)
hit=true;


if(
score>=40
&&
cactus+50<28
&&
cactus+50>10
&&
y>32
)
hit=true;



if(hit){

for(
int i=0;
i<3;
i++
){

digitalWrite(
BUZZER,
HIGH
);

delay(60);

digitalWrite(
BUZZER,
LOW
);

delay(50);

}

dead=true;

}




u8g2.clearBuffer();



// NIGHT MODE

if(score>=40){

u8g2.drawDisc(
105,
15,
6
);

for(
int i=0;
i<8;
i++
){

u8g2.drawPixel(
random(128),
random(25)
);

}

}



// SCORE

u8g2.setCursor(
0,
10
);

u8g2.print(
"Score:"
);

u8g2.print(
score
);



// LEVEL

u8g2.setCursor(
75,
10
);

if(score<20)
u8g2.print("Easy");

else if(score<40)
u8g2.print("Hard");

else
u8g2.print("Night");




// GROUND

if(score<40){

u8g2.drawLine(
0,
58,
128,
58
);

}

else{

for(
int i=0;
i<128;
i+=6
){

u8g2.drawPixel(
i,
58
);

}

}



// DINO

u8g2.drawBox(
10,
(int)y+6,
12,
8
);

u8g2.drawBox(
18,
(int)y+2,
8,
6
);

u8g2.drawPixel(
22,
(int)y+4
);

u8g2.drawBox(
22,
(int)y+7,
4,
2
);

u8g2.drawBox(
8,
(int)y+10,
2,
2
);

u8g2.drawBox(
13,
(int)y+13,
2,
4
);

u8g2.drawBox(
19,
(int)y+13,
2,
4
);

u8g2.drawBox(
15,
(int)y+10,
3,
2
);




// CACTUS 1

u8g2.drawLine(
cactus,
40,
cactus,
58
);

u8g2.drawLine(
cactus-3,
45,
cactus+3,
45
);

u8g2.drawLine(
cactus-3,
50,
cactus+3,
50
);




// CACTUS 2

if(score>=40){

u8g2.drawLine(
cactus+50,
40,
cactus+50,
58
);

u8g2.drawLine(
cactus+47,
45,
cactus+53,
45
);

u8g2.drawLine(
cactus+47,
50,
cactus+53,
50
);

}



u8g2.sendBuffer();

delay(15);

}
