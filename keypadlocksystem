#include <Keypad.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// LCD setup (address 0x27 is common)
LiquidCrystal_I2C lcd(0x27, 16, 2);

const byte ROWS = 4;
const byte COLS = 4;

// Keypad layout
char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

// Pins
byte rowPins[ROWS] = {9, 8, 7, 6};
byte colPins[COLS] = {5, 4, 3, 2};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// Outputs
int greenLED = 10;
int redLED = 11;
int buzzer = 12;

// Password
String password = "1234";
String input = "";

bool changeMode = false;

void setup() {
  lcd.init();
  lcd.backlight();

  pinMode(greenLED, OUTPUT);
  pinMode(redLED, OUTPUT);
  pinMode(buzzer, OUTPUT);

  lcd.setCursor(0, 0);
  lcd.print("Enter Password");
}

void loop() {
  char key = keypad.getKey();

  if (key) {

    // CLEAR
    if (key == '*') {
      input = "";
      lcd.clear();
      lcd.print("Cleared");
      delay(1000);
      lcd.clear();
      lcd.print("Enter Password");
    }

    // CHANGE MODE
    else if (key == '#') {
      lcd.clear();

      if (!changeMode) {
        changeMode = true;
        input = "";
        lcd.print("New Password:");
      } 
      else {
        password = input;
        changeMode = false;
        input = "";

        lcd.print("Password Changed");
        delay(1500);

        lcd.clear();
        lcd.print("Enter Password");
      }
    }

    // NORMAL INPUT
    else {
      input += key;

      lcd.setCursor(0, 1);
      lcd.print(input);

      // AUTO CHECK
      if (!changeMode && input.length() == password.length()) {

        lcd.clear();

        if (input == password) {
          lcd.print("Access Granted");

          digitalWrite(greenLED, HIGH);
          delay(2000);
          digitalWrite(greenLED, LOW);
        } 
        else {
          lcd.print("Incorrect Pass");

          digitalWrite(redLED, HIGH);

          for (int i = 0; i < 5; i++) {
            digitalWrite(buzzer, HIGH);
            delay(200);
            digitalWrite(buzzer, LOW);
            delay(200);
          }

          digitalWrite(redLED, LOW);
        }

        input = "";
        delay(1500);

        lcd.clear();
        lcd.print("Enter Password");
      }
    }
  }
}
